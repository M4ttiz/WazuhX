# Wazuh API (internal Docker network)
# Use WAZUH_USER / WAZUH_PASSWORD only (not WAZUH_API_USER)
WAZUH_API_URL=https://wazuh-manager:55000
WAZUH_USER=admin
WAZUH_PASSWORD=your_password_here

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Application
NODE_ENV=production
PORT=3001
CACHE_TTL_SECONDS=60
# Default client refresh hint (ms) — overridden per-page in Settings localStorage
REFRESH_INTERVAL_MS=30000
USE_MOCK=false

# Wazuh Indexer (OpenSearch) — required for alerts, CVE (4.8+), FIM events
# Use the same credentials as Wazuh Dashboard if not set separately
WAZUH_INDEXER_URL=https://wazuh-indexer:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=your_indexer_password_here

# Resource metrics thresholds (CPU/RAM %, disk %)
METRICS_CPU_THRESHOLD=90
METRICS_RAM_THRESHOLD=90
METRICS_DISK_THRESHOLD=85
METRICS_CACHE_TTL_SECONDS=5
METRICS_ALERT_COOLDOWN_SECONDS=600

# GET /api/metrics/realtime/:id cache (ms), clamped 0–5000
REALTIME_METRICS_CACHE_TTL_MS=2000

# Netdata (per-agent host IP from Wazuh; manager default below)
NETDATA_HOST=http://192.168.50.136:19999
NETDATA_PORT=19999
NETDATA_SCHEME=http
NETDATA_TIMEOUT_MS=2500
NETDATA_ENABLED=true

# Required for self-signed Wazuh certificates in Docker
NODE_TLS_REJECT_UNAUTHORIZED=0
